<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_out_invoice_tree_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="phone_number" readonly="1"/>
            </xpath>
        </field>
    </record>
    <record id="view_account_move_term_id_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//sheet//div[@name='due_date']//field[@name='invoice_payment_term_id']" position="attributes">
                <attribute name="domain">[('name', 'in', ['Immediate Payment', '15 Days', '21 Days', '30 Days'])]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
